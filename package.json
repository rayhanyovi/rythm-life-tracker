{
  "name": "rythm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "postinstall": "prisma generate",
    "build": "next build",
    "start": "next start",
    "discipline:check": "node --import tsx scripts/check-repo-discipline.ts",
    "docker:up": "docker compose up --build",
    "docker:db": "docker compose up db",
    "docker:down": "docker compose down --remove-orphans",
    "lint": "eslint",
    "verify": "npm run env:check && npm run prisma:validate && npm run test && npm run lint && npm run build",
    "verify:e2e": "npm run test:e2e",
    "env:check": "node --import tsx scripts/check-env.ts",
    "env:check:deployment": "node --import tsx scripts/check-env.ts --deployment",
    "qa:layout": "node --import tsx scripts/capture-layout-review.ts",
    "test": "node --test --import tsx tests/index.test.ts",
    "test:watch": "node --test --watch --import tsx tests/index.test.ts",
    "test:e2e": "cross-env NEXT_PUBLIC_PWA_DEV_ENABLED=true RYTHM_E2E_AUTH_BYPASS=true PLAYWRIGHT_APP_PORT=3100 BETTER_AUTH_URL=http://localhost:3100 playwright test",
    "seed:demo": "node --import tsx scripts/seed-demo.ts",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:status": "prisma migrate status",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "^1.5.4",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "better-auth": "^1.5.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "pg": "^8.20.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^7.4.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
