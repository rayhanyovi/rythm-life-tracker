generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum QuestType {
  DAILY
  WEEKLY
  MONTHLY
  MAIN
}

model User {
  id            String            @id
  email         String            @unique
  name          String
  emailVerified Boolean           @default(false) @map("email_verified")
  image         String?           @db.Text
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  sessions      Session[]
  accounts      Account[]
  categories    Category[]
  quests        Quest[]
  completions   QuestCompletion[]

  @@map("user")
}

model Session {
  id        String   @id
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_session_user_id")
  @@map("session")
}

model Account {
  id                    String    @id
  providerId            String    @map("provider_id")
  accountId             String    @map("account_id")
  userId                String    @map("user_id")
  accessToken           String?   @db.Text @map("access_token")
  refreshToken          String?   @db.Text @map("refresh_token")
  idToken               String?   @db.Text @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId], map: "account_provider_account_unique")
  @@index([userId], map: "idx_account_user_id")
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String   @unique
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("verification")
}

model Category {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quests    Quest[]

  @@unique([userId, name], map: "category_user_name_unique")
  @@index([userId, sortOrder], map: "idx_categories_user_sort")
  @@map("categories")
}

model Quest {
  id          String            @id @default(cuid())
  userId      String            @map("user_id")
  categoryId  String            @map("category_id")
  title       String
  description String?
  questType   QuestType         @map("quest_type")
  isActive    Boolean           @default(true) @map("is_active")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category          @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  completions QuestCompletion[]

  @@index([userId, categoryId], map: "idx_quests_user_category")
  @@index([userId, questType, isActive], map: "idx_quests_user_type_active")
  @@map("quests")
}

model QuestCompletion {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  questId     String    @map("quest_id")
  periodType  QuestType @map("period_type")
  periodKey   String    @map("period_key")
  completedAt DateTime  @default(now()) @map("completed_at")
  note        String?
  createdAt   DateTime  @default(now()) @map("created_at")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  quest       Quest     @relation(fields: [questId], references: [id], onDelete: Cascade)

  @@unique([userId, questId, periodType, periodKey], map: "completion_user_quest_period_unique")
  @@index([userId, questId, periodType, periodKey], map: "idx_completions_user_quest_period")
  @@index([userId, completedAt(sort: Desc)], map: "idx_completions_user_completed_at")
  @@map("quest_completions")
}
